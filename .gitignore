# Git ignore patterns for TrueReact

# Dependencies
node_modules/
__pycache__/
*.pyc
.pycache/
venv/
.venv/
env/

# Environment files
.env
.env.local
.env.*.local
*.env

# Build outputs
dist/
build/
*.egg-info/
.eggs/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Testing
.coverage
htmlcov/
.pytest_cache/
coverage/

# Mobile
*.apk
*.aab
*.ipa
*.dSYM.zip
*.dSYM
.expo/
expo-env.d.ts

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Secrets
secrets/
*.pem
*.key
credentials.json
