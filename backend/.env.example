# TrueReact Backend Environment Variables

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp

# Vertex AI Search Configuration
VERTEX_SEARCH_DATASTORE_ID=your-datastore-id
VERTEX_SEARCH_LOCATION=global

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# WebSocket Configuration
WS_MAX_CONNECTIONS=100
WS_HEARTBEAT_INTERVAL=30

# Safety Settings
DISTRESS_THRESHOLD=0.7
CRISIS_RESOURCE_ENABLED=true

# Grounding Settings (uses Google Search for evidence-based responses)
GOOGLE_SEARCH_GROUNDING_ENABLED=true
GROUNDING_DYNAMIC_THRESHOLD=0.3
